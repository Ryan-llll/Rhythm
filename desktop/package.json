{
  "name": "rhythm-desktop",
  "version": "1.0.0",
  "description": "Desktop wrapper for Rhythm Habit Tracker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "author": "Rayan Amlal",
  "license": "MIT",
  "devDependencies": {
    "electron": "^34.5.8",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.rhythm.app",
    "productName": "Rhythm",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dir"],
      "icon": "icon.icns"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "icon.icns"
    ]
  },
  "allowScripts": {
    "electron@34.5.8": true
  }
}
